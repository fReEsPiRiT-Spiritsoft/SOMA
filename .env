# ============================================================================
# SOMA-AI Environment Configuration
# CHANGE ALL SECRETS BEFORE PRODUCTION DEPLOYMENT
# ============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_DB=soma_db
POSTGRES_USER=soma
POSTGRES_PASSWORD=soma_secret_change_me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── MQTT (Mosquitto) ────────────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_WS_PORT=9001

# ── Ollama (LLM) ────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost
OLLAMA_PORT=11434
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_HEAVY_MODEL=llama3:latest
OLLAMA_LIGHT_MODEL=phi3:mini

# ── Brain Core (FastAPI) ────────────────────────────────────────────────
BRAIN_CORE_HOST=0.0.0.0
BRAIN_CORE_PORT=8100
BRAIN_CORE_WORKERS=4

# ── Django (Memory UI) ──────────────────────────────────────────────────
DJANGO_SECRET_KEY=soma-django-secret-change-me-in-production
DJANGO_DEBUG=True
DJANGO_HOST=0.0.0.0
DJANGO_PORT=8200

# ── System Health Thresholds ─────────────────────────────────────────────
HEALTH_RAM_WARN_PERCENT=75
HEALTH_RAM_CRITICAL_PERCENT=85
HEALTH_VRAM_WARN_PERCENT=75
HEALTH_VRAM_CRITICAL_PERCENT=85
HEALTH_CPU_WARN_PERCENT=80
HEALTH_TEMP_WARN_CELSIUS=75

# ── Home Assistant Bridge ───────────────────────────────────────────────
HA_URL=http://homeassistant.local:8123
HA_TOKEN=
# HA Entity fuer Hausdurchsagen ("all" = alle Lautsprecher)
HA_SPEAKER_ENTITY=media_player.all


# ── Phone Gateway (Asterisk / SIP Provider)
#
# SOMA unterstützt beliebige SIP-Provider (z.B. Sipgate, Linhome, IONOS, VoIP.ms).
# Trage hier die SIP-Serveradresse, Benutzer-ID und Passwort deines Providers ein.
# Wenn du "Linhome" nutzen willst, setze hier den Host/ID/Pass entsprechend.
# Beispiel (Sipgate):
#   VODAFONE_SIP_HOST=sipgate.de
#   VODAFONE_SIP_USER=1234567e0
#   VODAFONE_SIP_PASS=meinSIPPasswort
#
# Beispiel (linhome) — ersetze die Werte durch deine tatsächlichen Zugangsdaten:
#   VODAFONE_SIP_HOST=sip.linhome.example
#   VODAFONE_SIP_USER=dein_linhome_user
#   VODAFONE_SIP_PASS=dein_linhome_pass

VODAFONE_SIP_HOST=
VODAFONE_SIP_USER=
VODAFONE_SIP_PASS=

# Passwort das du am Telefon sprichst um Soma freizuschalten
SOMA_PHONE_PASSWORD=starlight

# Asterisk ARI-Passwort (intern, kann so bleiben)
ASTERISK_ARI_PASS=soma_ari_secret

# Die LAN-IP dieses Rechners — damit HA die TTS-Audiodateien abrufen kann
# Beispiel: http://192.168.0.50:8100
SOMA_LOCAL_URL=http://192.168.0.100:8100
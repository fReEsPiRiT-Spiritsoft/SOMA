# ============================================================================
# SOMA-AI Environment Configuration – BEISPIEL-DATEI
# Kopiere diese Datei nach .env und trage deine echten Werte ein:
#   cp .env.example .env
# ============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_DB=soma_db
POSTGRES_USER=soma
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── MQTT (Mosquitto) ────────────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_WS_PORT=9001

# ── Ollama (LLM) ────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost
OLLAMA_PORT=11434
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=3
OLLAMA_HEAVY_MODEL=gemma4:e4b
OLLAMA_LIGHT_MODEL=qwen3:1.7b
# Warm Pool: keep_alive pro Modell (Ollama-Syntax: "5m", "-1"=permanent, "0"=sofort entladen)
OLLAMA_HEAVY_KEEP_ALIVE=5m
OLLAMA_LIGHT_KEEP_ALIVE=-1s

# ── Brain Core (FastAPI) ────────────────────────────────────────────────
BRAIN_CORE_HOST=0.0.0.0
BRAIN_CORE_PORT=8100
BRAIN_CORE_WORKERS=4

# ── Django (Memory UI) ──────────────────────────────────────────────────
DJANGO_SECRET_KEY=CHANGE_ME_generate_with_python_-c_secrets.token_hex_50
DJANGO_DEBUG=True
DJANGO_HOST=0.0.0.0
DJANGO_PORT=8200

# ── System Health Thresholds ─────────────────────────────────────────────
HEALTH_RAM_WARN_PERCENT=75
HEALTH_RAM_CRITICAL_PERCENT=85
HEALTH_VRAM_WARN_PERCENT=75
HEALTH_VRAM_CRITICAL_PERCENT=85
HEALTH_CPU_WARN_PERCENT=80
HEALTH_TEMP_WARN_CELSIUS=75

# ── GitHub Models API (Plugin Code-Generierung) ─────────────────────────
# GitHub PAT mit 'models:read' Scope erstellen:
# https://github.com/settings/tokens → Fine-grained token → models:read
# NUR für Plugin-Code-Generierung — alles andere bleibt lokal!
GITHUB_TOKEN=github_pat_CHANGE_ME_your_token_here
# Modell: o4-mini (schnell+günstig), o1-mini, o1-preview, gpt-4o
GITHUB_MODELS_MODEL=o4-mini

# ── Home Assistant Bridge ───────────────────────────────────────────────
HA_URL=http://homeassistant.local:8123
HA_TOKEN=
# HA Entity fuer Hausdurchsagen ("all" = alle Lautsprecher)
HA_SPEAKER_ENTITY=media_player.all

# ── Phone Gateway (Asterisk / Linhome SIP) ───────────────────────────────
# SIP-Adresse:   sip:DEIN_SIP_USER@sip.linhome.org
# Registrar:     sip:sip.linhome.org
#
# ⚠  Echte Zugangsdaten aus deiner Linhome-App eintragen!
VODAFONE_SIP_HOST=sip.linhome.org
VODAFONE_SIP_USER=CHANGE_ME_sip_username
VODAFONE_SIP_PASS=CHANGE_ME_sip_password

# Linphone SIP-Client (Smartphone im LAN oder per VPN)
# App-Einstellung: SIP-Adresse = sip:soma@192.168.0.100, Port 5060 UDP
LINPHONE_SIP_PASS=CHANGE_ME_linphone_password

# Passwort das du am Telefon sprichst um Soma freizuschalten
SOMA_PHONE_PASSWORD=CHANGE_ME_voice_unlock_word

# ── Remote Mobile Access ────────────────────────────────────────────────
# API Key für mobilen Fernzugriff (z.B. vom Handy unterwegs).
# Generieren mit: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Setze diesen Key in der SOMA Mobile App unter Einstellungen.
REMOTE_API_KEY=

# Asterisk ARI-Passwort (intern, kann so bleiben oder ändern)
ASTERISK_ARI_PASS=soma_ari_secret

# Die LAN-IP dieses Rechners — damit HA die TTS-Audiodateien abrufen kann
# Beispiel: http://192.168.0.50:8100
SOMA_LOCAL_URL=http://192.168.0.100:8100

    "files": {
      "icon": "📁",
      "label": "DATEIEN",
      "tags": {
        "file": {
          "description": "Dateisystem-Operationen",
          "params": {
            "action":  {"required": true,  "type": "string", "hint": "read, write, list, search, grep, copy, move, delete, info, mkdir, open"},
            "path":    {"required": true,  "type": "string"},
            "content": {"required": false, "type": "string", "hint": "Für write"},
            "pattern": {"required": false, "type": "string", "hint": "Für search/grep"},
            "append":  {"required": false, "type": "string", "hint": "true/false für write"}
          },
          "examples": [
            "[ACTION:file action=\"read\" path=\"~/Dokumente/notizen.txt\"]",
            "[ACTION:file action=\"search\" pattern=\"BeamNG\" path=\"~\"]"
          ],
          "tts_confirm": true,
          "nano_capable": false,
          "needs_reask": false,
          "concurrency_safe": false,
          "is_read_only": false,
          "is_destructive": true,
          "timeout_ms": 30000,
          "search_hint": "datei lesen schreiben suchen ordner",
          "do_rules": [
            "Vor destruktiven Operationen (delete, move) Bestätigung einholen",
            "Bei großen Dateien nur Ausschnitte lesen"
          ],
          "dont_rules": [
            "Niemals Systemdateien überschreiben",
            "Keine rekursiven Löschungen ohne Bestätigung"
          ]
        },
        "file_edit": {
          "description": "Präzises Bearbeiten: Search-and-Replace statt Datei überschreiben (Claude Code Pattern)",
          "params": {
            "path":           {"required": true,  "type": "string", "hint": "Dateipfad"},
            "old_text":       {"required": true,  "type": "string", "hint": "Exakter Text zum Ersetzen (inkl. Whitespace!)"},
            "new_text":       {"required": true,  "type": "string", "hint": "Neuer Text"},
            "expected_count": {"required": false, "type": "number", "hint": "Wie oft muss old_text vorkommen? (default: 1)"},
            "dry_run":        {"required": false, "type": "string", "hint": "true = nur simulieren"}
          },
          "examples": [
            "[ACTION:file_edit path=\"main.py\" old_text=\"def foo():\" new_text=\"def bar():\"]",
            "[ACTION:file_edit path=\"config.json\" old_text=\"\\\"debug\\\": false\" new_text=\"\\\"debug\\\": true\"]"
          ],
          "tts_confirm": true,
          "nano_capable": false,
          "needs_reask": false,
          "concurrency_safe": false,
          "is_read_only": false,
          "is_destructive": false,
          "timeout_ms": 15000,
          "search_hint": "ersetzen ändern bearbeiten edit replace refactor",
          "do_rules": [
            "Inkludiere 3-5 Zeilen Kontext in old_text für eindeutigen Match",
            "Prüfe mit dry_run=true bevor du änderst",
            "Lies die Datei vorher mit file action='read' um den exakten Text zu sehen"
          ],
          "dont_rules": [
            "Niemals raten wie der Text aussieht — immer erst lesen!",
            "Nicht für komplett neue Dateien nutzen — dafür file action='write'",
            "Kein Whitespace ignorieren — old_text muss EXAKT matchen"
          ]
        },
        "file_insert": {
          "description": "Text an einer bestimmten Zeilennummer einfügen",
          "params": {
            "path":        {"required": true,  "type": "string"},
            "line_number": {"required": true,  "type": "number", "hint": "Zeilennummer (1-basiert)"},
            "text":        {"required": true,  "type": "string"},
            "after":       {"required": false, "type": "string", "hint": "true = nach Zeile, false = vor Zeile"}
          },
          "examples": [
            "[ACTION:file_insert path=\"main.py\" line_number=10 text=\"# Neuer Kommentar\"]"
          ],
          "tts_confirm": true,
          "nano_capable": false,
          "needs_reask": false,
          "concurrency_safe": false,
          "is_read_only": false,
          "is_destructive": false,
          "timeout_ms": 10000,
          "search_hint": "einfügen zeile insert line"
        },
        "file_delete_lines": {
          "description": "Zeilen aus einer Datei löschen",
          "params": {
            "path":       {"required": true, "type": "string"},
            "start_line": {"required": true, "type": "number", "hint": "Erste zu löschende Zeile"},
            "end_line":   {"required": true, "type": "number", "hint": "Letzte zu löschende Zeile"}
          },
          "examples": [
            "[ACTION:file_delete_lines path=\"main.py\" start_line=5 end_line=10]"
          ],
          "tts_confirm": true,
          "nano_capable": false,
          "needs_reask": false,
          "concurrency_safe": false,
          "is_read_only": false,
          "is_destructive": true,
          "timeout_ms": 10000,
          "search_hint": "löschen zeilen entfernen delete lines"
        }
      }
    },


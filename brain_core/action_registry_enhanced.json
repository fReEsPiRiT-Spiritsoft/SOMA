{
  "_meta": {
    "version": "2.0",
    "description": "SOMA-AI Action Tag Registry — Enhanced mit Claude Code Patterns",
    "format": "[ACTION:type key=\"value\" key2=\"value2\"]",
    "notes": "Extended mit: concurrency_safe, retry_policy, is_destructive, timeout_ms, search_hint"
  },

  "categories": {
    "smart_home": {
      "icon": "🏠",
      "label": "SMART HOME",
      "tags": {
        "ha_call": {
          "description": "Home Assistant Service Call (Licht, Heizung, Schalter, etc.)",
          "params": {
            "domain":         {"required": true,  "type": "string", "hint": "light, climate, switch, media_player, ..."},
            "service":        {"required": true,  "type": "string", "hint": "turn_on, turn_off, toggle, set_temperature, ..."},
            "entity_id":      {"required": true,  "type": "string", "hint": "light.wohnzimmer, climate.schlafzimmer, ..."},
            "brightness_pct": {"required": false, "type": "number", "hint": "0-100"},
            "temperature":    {"required": false, "type": "number", "hint": "Grad Celsius"},
            "hvac_mode":      {"required": false, "type": "string", "hint": "heat, cool, auto, off"},
            "volume_level":   {"required": false, "type": "number", "hint": "0.0-1.0"},
            "color_temp":     {"required": false, "type": "number"},
            "rgb_color":      {"required": false, "type": "string"}
          },
          "examples": [
            "[ACTION:ha_call domain=\"light\" service=\"turn_on\" entity_id=\"light.wohnzimmer\"]",
            "[ACTION:ha_call domain=\"light\" service=\"turn_on\" entity_id=\"light.wohnzimmer\" brightness_pct=\"80\"]"
          ],
          "tts_confirm": true,
          "nano_capable": true,
          "needs_reask": false,
          "concurrency_safe": true,
          "is_read_only": false,
          "is_destructive": false,
          "timeout_ms": 5000,
          "retry_policy": {"max_retries": 3, "backoff_ms": 500},
          "search_hint": "licht lampe heizung schalter smart home"
        },
        "ha_tts": {
          "description": "Hausdurchsage über HA-Lautsprecher (Piper TTS → HA media_player)",
          "params": {
            "text": {"required": true, "type": "string", "hint": "Die Nachricht die gesprochen wird"},
            "room": {"required": false, "type": "string", "hint": "all, wohnzimmer, küche, ... (default: all)"}
          },
          "examples": [
            "[ACTION:ha_tts text=\"Das Essen ist fertig!\" room=\"all\"]"
          ],
          "tts_confirm": true,
          "nano_capable": false,
          "needs_reask": false,
          "concurrency_safe": true,
          "is_read_only": false,
          "is_destructive": false,
          "timeout_ms": 10000,
          "search_hint": "ansage durchsage sprechen lautsprecher"
        }
      }
    },

